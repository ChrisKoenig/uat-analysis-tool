.git
.github

# IDE
.vscode

# Python caches
__pycache__
*.pyc
*.pyo

# Node modules (will be installed fresh in container)
node_modules

# Markdown / documentation (not needed in containers)
*.md

# Old backups and archives
archive/
backup_*/

# Infrastructure-as-code (not needed at runtime)
infrastructure/

# Local caches
.cache/
cache/
field-portal/cache/

# PowerShell scripts
*.ps1

# Log files
*.log

# Build outputs (UI rebuilt in container)
triage-ui/dist/
field-portal/ui/dist/

