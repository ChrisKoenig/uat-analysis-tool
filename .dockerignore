migrate_*.py
add_*.py
assign_*.py
check_*.py
find_*.py
get_resource_*.py
resolve_*.py
update_*.py
configure_*.py
disable_*.py
authenticate_*.py

# Test files
test_*.py

# Admin service (not being containerized)
admin_service.py
admin-service/

# Microservice agents (not being containerized in this pass)
agents/

